# Alpha Radar 环境变量配置
# 复制此文件为 .env 并填入实际值

# =============================================================================
# 必需配置
# =============================================================================

# DeepSeek AI API Key（主要 AI 提供商）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 企业微信机器人 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# =============================================================================
# AI 备用提供商（推荐配置，用于降级策略）
# =============================================================================

# OpenRouter - 支持 Claude/GPT 等多种模型
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# OpenAI - 直接使用 GPT 模型
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude（直接接入）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# 推送渠道（可选）
# =============================================================================

# 钉钉机器人
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx
DINGTALK_SECRET=SEC-xxxxxxxxxxxxxxxx

# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx/xxxx/xxxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=xxxxxxxx:xxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxx

# Feishu (飞书) 机器人 - 国内企业常用
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
FEISHU_SECRET=xxxxxxxxxxxxxxxx

# ntfy - 开源手机推送（可自建服务器）
NTFY_TOPIC=your-topic-name
NTFY_SERVER=https://ntfy.sh

# Bark - iOS 推送 App
BARK_DEVICE_KEY=your-device-key
BARK_SERVER=https://api.day.app

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_TO=recipient@example.com

# =============================================================================
# Twitter 抓取第三方 API（可选，用于稳定抓取）
# =============================================================================

TWITTERAPI_KEY=xxxxxxxx
SCRAPFLY_KEY=sf-xxxxxxxx

# =============================================================================
# 数据库（可选，不填则仅使用本地 SQLite）
# =============================================================================

# Supabase 云端同步
USE_SUPABASE=false
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# 服务配置
# =============================================================================

# 服务端口（默认 3001）
PORT=3001

# API 端点保护密钥（设置后需通过 X-API-Key Header 访问写操作）
API_SECRET=your-secret-key-for-api-protection

# CORS 允许的来源（生产环境必须配置）
# 多个来源用逗号分隔: https://app1.com,https://app2.com
CORS_ORIGIN=https://your-domain.com

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info

# =============================================================================
# 应用 URL（用于第三方服务回调和推送消息链接）
# =============================================================================

APP_URL=https://alpha-radar.vercel.app
DASHBOARD_URL=http://localhost:3001

# Vercel 自动提供的环境变量，本地开发时手动设置
VERCEL_URL=alpha-radar.vercel.app

# =============================================================================
# 导出与集成（可选）
# =============================================================================

# Notion API - 用于高价值情报自动写入
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Token - 用于 Issues/Releases 集成
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=username/repo-name

# =============================================================================
# 高级配置（通常不需要修改）
# =============================================================================

# 情报密度预警阈值：跨多少个不同来源提到同一话题时触发预警
MONITOR_ALERT_THRESHOLD=3

# 是否启用基于 Zod 的严格 JSON 校验
AI_STRICT_MODE=false

# GitHub Actions / CI 专用（本地无需填写）
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
